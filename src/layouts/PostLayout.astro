---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagList from '../components/TagList.astro';
import '../styles/article.css';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags: string[];
  radarQuadrant?: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, updatedDate, tags, radarQuadrant, headings } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const updatedFormatted = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | CJ Blog`} description={description} ogType="article" publishedDate={date} tags={tags}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {updatedDate && <span class="updated">Updated {updatedFormatted}</span>}
      </div>
      {tags.length > 0 && <TagList tags={tags} />}
      {radarQuadrant && (
        <a href={`https://cjunker.dev/#tech-radar`} class="radar-link" rel="noopener">
          View on Tech Radar
        </a>
      )}
    </header>

    <TableOfContents headings={headings} />

    <div class="article-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/" class="back-link">All Posts</a>
      <a href="https://cjunker.dev" class="back-link" rel="noopener">Portfolio</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg);
  }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: var(--border-thick) solid var(--c-border);
  }

  .post-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--c-ink-light);
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    display: flex;
    gap: var(--space-md);
  }

  .updated {
    color: var(--c-accent);
  }

  .radar-link {
    display: inline-block;
    margin-top: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    font-weight: 700;
    color: var(--c-accent);
    padding: var(--space-2xs) var(--space-xs);
    border: 1px solid var(--c-accent);
  }

  .post-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: var(--border-thick) solid var(--c-border);
    display: flex;
    gap: var(--space-lg);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    font-weight: 700;
    color: var(--c-ink);
    text-decoration: none;
    padding: var(--space-xs) var(--space-md);
    border: var(--border-thick) solid var(--c-border);
    box-shadow: var(--shadow-sm) var(--c-shadow);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .back-link:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--c-shadow);
  }
</style>
