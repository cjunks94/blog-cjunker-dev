---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <div class="post-card-header">
    <time datetime={date.toISOString()} class="post-date">{formattedDate}</time>
  </div>
  <div class="post-card-content">
    <h2 class="post-title">
      <a href={`/${slug}`}>{title}</a>
    </h2>
    <p class="post-description">{description}</p>
    {tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .post-card {
    background: var(--c-surface);
    border: var(--border-thick) solid var(--c-border);
    box-shadow: var(--shadow-sm) var(--c-shadow);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .post-card:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--c-shadow);
  }

  .post-card-header {
    padding: var(--space-sm) var(--space-lg);
    border-bottom: var(--border-thin) solid var(--c-border);
    background: var(--c-surface-alt);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    color: var(--c-ink-light);
  }

  .post-card-content {
    padding: var(--space-lg);
  }

  .post-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .post-title a {
    color: var(--c-ink);
    text-decoration: none;
  }

  .post-title a:hover {
    color: var(--c-accent);
  }

  .post-description {
    color: var(--c-ink-light);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-md);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    font-weight: 700;
    color: var(--c-accent);
    text-decoration: none;
    padding: var(--space-2xs) var(--space-xs);
    border: 1px solid var(--c-accent);
  }

  .tag:hover {
    background: var(--c-accent);
    color: var(--c-surface);
  }
</style>
